{
  "name": "crew",
  "version": "0.1.0",
  "description": "Provider-agnostic multi-agent coding crew through conversation",
  "type": "module",
  "bin": {
    "crew": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "defaults"
  ],
  "keywords": [
    "ai",
    "agent",
    "crew",
    "claude",
    "codex",
    "multi-agent",
    "cli"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "eventemitter3": "^5.0.4",
    "execa": "^9.6.1",
    "ink": "^7.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.5",
    "simple-git": "^3.36.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
