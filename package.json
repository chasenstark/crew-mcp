{
  "name": "crew-mcp",
  "version": "0.2.0-dev",
  "description": "MCP server + portable captain skill that turns any AI coding CLI into the orchestrator of a worktree-isolated multi-agent crew",
  "type": "module",
  "bin": {
    "crew": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "skills"
  ],
  "keywords": [
    "ai",
    "agent",
    "mcp",
    "claude",
    "codex",
    "gemini",
    "multi-agent",
    "orchestration",
    "cli"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "eventemitter3": "^5.0.4",
    "execa": "^9.6.1",
    "simple-git": "^3.36.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
